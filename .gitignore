# ─── Flutter / Dart ───────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
.metadata
**/doc/api/
**/ios/Flutter/.last_build_id

# Symbolication & obfuscation artifacts
app.*.symbols
app.*.map.json

# Generated native splash / icon scratch output
**/*.png.webp

# ─── Android ──────────────────────────────────────────────────────────
android/.gradle/
android/captures/
android/local.properties           # contains absolute sdk.dir
android/key.properties             # signing — keep secret
android/app/debug/
android/app/profile/
android/app/release/
**/*.keystore
**/*.jks

# NOTE: gradlew, gradlew.bat, and android/gradle/wrapper/ ARE committed
# so every machine/CI uses the same Gradle version.

# ─── iOS (kept even though project is Android-first) ──────────────────
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Pods/
ios/.symlinks/
ios/Runner.xcworkspace/xcuserdata/
**/ios/Flutter/.last_build_id

# ─── IDE ──────────────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
# If you want to commit shared launch configs, comment the line above and
# whitelist individual files in .vscode/ instead.

# ─── Build outputs (loose copies) ─────────────────────────────────────
*.apk
*.aab
*.ipa

# ─── OS junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Logs / scratch ───────────────────────────────────────────────────
*.log
*.pyc
*.swp
*.swo
.history/
.atom/

# ─── Secrets / env ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Coverage ─────────────────────────────────────────────────────────
coverage/
lcov.info

# ─── Alarm sound asset (optional — uncomment if you don't want to
# commit the mp3 you drop in) ─────────────────────────────────────────
# assets/audio/alarm.mp3
